<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.MedicalRecordMapper">

    <resultMap type="DrmMedicalRecord" id="MedicalRecordResult">
        <result property="recordId"    column="record_id"    />
        <result property="recordName"    column="record_name"    />
        <result property="deptName"    column="dept_name"    />
        <result property="recordValue"    column="record_value"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectMedicalRecordVo">
        select record_id, record_name, dept_name, record_value, status, create_by, create_time, update_by, update_time, remark from drm_medical_record
    </sql>

    <select id="selectMedicalRecordList" parameterType="DrmMedicalRecord" resultMap="MedicalRecordResult">
        <include refid="selectMedicalRecordVo"/>
        <where>  
            <if test="recordName != null and recordName != ''"> and record_name like concat('%', #{recordName}, '%')</if>
            <if test="deptName != null and deptName != ''"> and dept_name = #{deptName}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectMedicalRecordById" parameterType="Long" resultMap="MedicalRecordResult">
        <include refid="selectMedicalRecordVo"/>
        where record_id = #{id}
    </select>
        
    <insert id="insertMedicalRecord" parameterType="DrmMedicalRecord" useGeneratedKeys="true" keyProperty="recordId">
        insert into drm_medical_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="recordName != null">record_name,</if>
            <if test="deptName != null">dept_name,</if>
            <if test="recordValue != null">record_value,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="recordName != null">#{recordName},</if>
            <if test="deptName != null">#{deptName},</if>
            <if test="recordValue != null">#{recordValue},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateMedicalRecord" parameterType="DrmMedicalRecord">
        update drm_medical_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="recordName != null">record_name = #{recordName},</if>
            <if test="deptName != null">dept_name = #{deptName},</if>
            <if test="recordValue != null">record_value = #{recordValue},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where record_id = #{recordId}
    </update>

    <delete id="deleteMedicalRecordById" parameterType="Long">
        delete from drm_medical_record where record_id = #{id}
    </delete>

    <delete id="deleteMedicalRecordByIds" parameterType="String">
        delete from drm_medical_record where record_id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
