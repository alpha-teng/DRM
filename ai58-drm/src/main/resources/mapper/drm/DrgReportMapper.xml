<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.DrgReportMapper">
    <resultMap type="DrgReport" id="DrgReportResult">
        <result property="reportId"        column="report_id"        />
        <result property="reportTitle"     column="report_title"     />
        <result property="reportPeriod"    column="report_period"    />
        <result property="targetDept"      column="target_dept"      />
        <result property="drgAnalysis"     column="drg_analysis"     />
        <result property="content"         column="content"          />
        <result property="status"          column="status"           />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
    </resultMap>

    <sql id="selectDrgReportVo">
        select report_id, report_title, report_period, target_dept, drg_analysis, content,
               status, create_by, create_time, update_by, update_time, remark
        from drm_drg_report
    </sql>

    <select id="selectDrgReportList" parameterType="DrgReport" resultMap="DrgReportResult">
        <include refid="selectDrgReportVo"/>
        <where>
            <if test="reportTitle != null and reportTitle != ''"> and report_title like concat('%', #{reportTitle}, '%')</if>
            <if test="reportPeriod != null and reportPeriod != ''"> and report_period = #{reportPeriod}</if>
            <if test="targetDept != null and targetDept != ''"> and target_dept like concat('%', #{targetDept}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectDrgReportById" parameterType="Long" resultMap="DrgReportResult">
        <include refid="selectDrgReportVo"/>
        where report_id = #{reportId}
    </select>

    <insert id="insertDrgReport" parameterType="DrgReport" useGeneratedKeys="true" keyProperty="reportId">
        insert into drm_drg_report
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="reportTitle != null and reportTitle != ''">report_title,</if>
            <if test="reportPeriod != null and reportPeriod != ''">report_period,</if>
            <if test="targetDept != null and targetDept != ''">target_dept,</if>
            <if test="drgAnalysis != null">drg_analysis,</if>
            <if test="content != null">content,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="reportTitle != null and reportTitle != ''">#{reportTitle},</if>
            <if test="reportPeriod != null and reportPeriod != ''">#{reportPeriod},</if>
            <if test="targetDept != null and targetDept != ''">#{targetDept},</if>
            <if test="drgAnalysis != null">#{drgAnalysis},</if>
            <if test="content != null">#{content},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateDrgReport" parameterType="DrgReport">
        update drm_drg_report
        <trim prefix="SET" suffixOverrides=",">
            <if test="reportTitle != null and reportTitle != ''">report_title = #{reportTitle},</if>
            <if test="reportPeriod != null and reportPeriod != ''">report_period = #{reportPeriod},</if>
            <if test="targetDept != null and targetDept != ''">target_dept = #{targetDept},</if>
            <if test="drgAnalysis != null">drg_analysis = #{drgAnalysis},</if>
            <if test="content != null">content = #{content},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where report_id = #{reportId}
    </update>

    <delete id="deleteDrgReportById" parameterType="Long">
        delete from drm_drg_report where report_id = #{reportId}
    </delete>

    <delete id="deleteDrgReportByIds" parameterType="Long">
        delete from drm_drg_report where report_id in
        <foreach item="reportId" collection="array" open="(" separator="," close=")">
            #{reportId}
        </foreach>
    </delete>
</mapper>
