<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.DrgPerfMapper">
    <resultMap type="DrgPerf" id="DrgPerfResult">
        <result property="perfId"       column="perf_id"       />
        <result property="deptName"     column="dept_name"     />
        <result property="drgCode"      column="drg_code"      />
        <result property="drgName"      column="drg_name"      />
        <result property="caseCnt"      column="case_cnt"      />
        <result property="perfScore"    column="perf_score"    />
        <result property="perfAmount"   column="perf_amount"   />
        <result property="calcDate"     column="calc_date"     />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectDrgPerfVo">
        select perf_id, dept_name, drg_code, drg_name, case_cnt, perf_score, perf_amount,
               calc_date, status, create_by, create_time, update_by, update_time, remark
        from drm_drg_perf
    </sql>

    <select id="selectDrgPerfList" parameterType="DrgPerf" resultMap="DrgPerfResult">
        <include refid="selectDrgPerfVo"/>
        <where>
            <if test="deptName != null and deptName != ''"> and dept_name like concat('%', #{deptName}, '%')</if>
            <if test="drgCode != null and drgCode != ''"> and drg_code = #{drgCode}</if>
            <if test="calcDate != null and calcDate != ''"> and calc_date = #{calcDate}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectDrgPerfById" parameterType="Long" resultMap="DrgPerfResult">
        <include refid="selectDrgPerfVo"/>
        where perf_id = #{perfId}
    </select>

    <insert id="insertDrgPerf" parameterType="DrgPerf" useGeneratedKeys="true" keyProperty="perfId">
        insert into drm_drg_perf
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">dept_name,</if>
            <if test="drgCode != null and drgCode != ''">drg_code,</if>
            <if test="drgName != null and drgName != ''">drg_name,</if>
            <if test="caseCnt != null">case_cnt,</if>
            <if test="perfScore != null">perf_score,</if>
            <if test="perfAmount != null">perf_amount,</if>
            <if test="calcDate != null">calc_date,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">#{deptName},</if>
            <if test="drgCode != null and drgCode != ''">#{drgCode},</if>
            <if test="drgName != null and drgName != ''">#{drgName},</if>
            <if test="caseCnt != null">#{caseCnt},</if>
            <if test="perfScore != null">#{perfScore},</if>
            <if test="perfAmount != null">#{perfAmount},</if>
            <if test="calcDate != null">#{calcDate},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateDrgPerf" parameterType="DrgPerf">
        update drm_drg_perf
        <trim prefix="SET" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">dept_name = #{deptName},</if>
            <if test="drgCode != null and drgCode != ''">drg_code = #{drgCode},</if>
            <if test="drgName != null and drgName != ''">drg_name = #{drgName},</if>
            <if test="caseCnt != null">case_cnt = #{caseCnt},</if>
            <if test="perfScore != null">perf_score = #{perfScore},</if>
            <if test="perfAmount != null">perf_amount = #{perfAmount},</if>
            <if test="calcDate != null">calc_date = #{calcDate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where perf_id = #{perfId}
    </update>

    <delete id="deleteDrgPerfById" parameterType="Long">
        delete from drm_drg_perf where perf_id = #{perfId}
    </delete>

    <delete id="deleteDrgPerfByIds" parameterType="Long">
        delete from drm_drg_perf where perf_id in
        <foreach item="perfId" collection="array" open="(" separator="," close=")">
            #{perfId}
        </foreach>
    </delete>
</mapper>
