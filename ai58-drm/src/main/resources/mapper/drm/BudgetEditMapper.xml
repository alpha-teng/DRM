<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.BudgetEditMapper">
    <resultMap type="BudgetEdit" id="BudgetEditResult">
        <result property="budgetId"        column="budget_id"        />
        <result property="budgetYear"      column="budget_year"      />
        <result property="budgetType"      column="budget_type"      />
        <result property="deptName"        column="dept_name"        />
        <result property="budgetAmount"    column="budget_amount"    />
        <result property="status"          column="status"           />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
    </resultMap>

    <sql id="selectBudgetEditVo">
        select budget_id, budget_year, budget_type, dept_name, budget_amount,
               status, create_by, create_time, update_by, update_time, remark
        from drm_budget_edit
    </sql>

    <select id="selectBudgetEditList" parameterType="BudgetEdit" resultMap="BudgetEditResult">
        <include refid="selectBudgetEditVo"/>
        <where>
            <if test="budgetYear != null and budgetYear != ''"> and budget_year = #{budgetYear}</if>
            <if test="budgetType != null and budgetType != ''"> and budget_type = #{budgetType}</if>
            <if test="deptName != null and deptName != ''"> and dept_name like concat('%', #{deptName}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectBudgetEditById" parameterType="Long" resultMap="BudgetEditResult">
        <include refid="selectBudgetEditVo"/>
        where budget_id = #{budgetId}
    </select>

    <insert id="insertBudgetEdit" parameterType="BudgetEdit" useGeneratedKeys="true" keyProperty="budgetId">
        insert into drm_budget_edit
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="budgetYear != null and budgetYear != ''">budget_year,</if>
            <if test="budgetType != null and budgetType != ''">budget_type,</if>
            <if test="deptName != null and deptName != ''">dept_name,</if>
            <if test="budgetAmount != null">budget_amount,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="budgetYear != null and budgetYear != ''">#{budgetYear},</if>
            <if test="budgetType != null and budgetType != ''">#{budgetType},</if>
            <if test="deptName != null and deptName != ''">#{deptName},</if>
            <if test="budgetAmount != null">#{budgetAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateBudgetEdit" parameterType="BudgetEdit">
        update drm_budget_edit
        <trim prefix="SET" suffixOverrides=",">
            <if test="budgetYear != null and budgetYear != ''">budget_year = #{budgetYear},</if>
            <if test="budgetType != null and budgetType != ''">budget_type = #{budgetType},</if>
            <if test="deptName != null and deptName != ''">dept_name = #{deptName},</if>
            <if test="budgetAmount != null">budget_amount = #{budgetAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where budget_id = #{budgetId}
    </update>

    <delete id="deleteBudgetEditById" parameterType="Long">
        delete from drm_budget_edit where budget_id = #{budgetId}
    </delete>

    <delete id="deleteBudgetEditByIds" parameterType="Long">
        delete from drm_budget_edit where budget_id in
        <foreach item="budgetId" collection="array" open="(" separator="," close=")">
            #{budgetId}
        </foreach>
    </delete>
</mapper>
