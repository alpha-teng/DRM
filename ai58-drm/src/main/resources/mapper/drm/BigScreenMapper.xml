<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.BigScreenMapper">

    <resultMap type="BigScreen" id="BigScreenResult">
        <id     property="screenId"      column="screen_id"      />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
        <result property="screenName" column="screen_name" />
        <result property="screenType" column="screen_type" />
        <result property="layoutConfig" column="layout_config" />
        <result property="theme" column="theme" />
        <result property="status" column="status" />
    </resultMap>

    <sql id="selectBigScreenVo">
        select screen_id, screen_name, screen_type, layout_config, theme, status, create_by, create_time, update_by, update_time, remark
        from drm_big_screen
    </sql>

    <select id="selectBigScreen" parameterType="BigScreen" resultMap="BigScreenResult">
        <include refid="selectBigScreenVo"/>
        <where>
            <if test="screenId != null">
                and screen_id = #{screenId}
            </if>
        </where>
    </select>

    <select id="selectBigScreenList" parameterType="BigScreen" resultMap="BigScreenResult">
        <include refid="selectBigScreenVo"/>
        <where>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
    </select>

    <insert id="insertBigScreen" parameterType="BigScreen">
        insert into drm_big_screen (
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateBigScreen" parameterType="BigScreen">
        update drm_big_screen
        <set>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where screen_id = #{screenId}
    </update>

    <delete id="deleteBigScreenById" parameterType="Long">
        delete from drm_big_screen where screen_id = #{screenId}
    </delete>

    <delete id="deleteBigScreenByIds" parameterType="Long">
        delete from drm_big_screen where screen_id in
        <foreach item="screenId" collection="array" open="(" separator="," close=")">
            #{screenId}
        </foreach>
    </delete>

</mapper>