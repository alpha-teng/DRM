<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.PerfPlanMapper">

    <resultMap type="PerfPlan" id="PerfPlanResult">
        <id     property="planId"      column="plan_id"      />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
        <result property="planName" column="plan_name" />
        <result property="planType" column="plan_type" />
        <result property="effectiveDate" column="effective_date" />
        <result property="status" column="status" />
        <result property="formulaConfig" column="formula_config" />
    </resultMap>

    <sql id="selectPerfPlanVo">
        select plan_id, plan_name, plan_type, effective_date, status, formula_config, create_by, create_time, update_by, update_time, remark
        from drm_perf_plan
    </sql>

    <select id="selectPerfPlan" parameterType="PerfPlan" resultMap="PerfPlanResult">
        <include refid="selectPerfPlanVo"/>
        <where>
            <if test="planId != null">
                and plan_id = #{screenId}
            </if>
        </where>
    </select>

    <select id="selectPerfPlanList" parameterType="PerfPlan" resultMap="PerfPlanResult">
        <include refid="selectPerfPlanVo"/>
        <where>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
    </select>

    <insert id="insertPerfPlan" parameterType="PerfPlan">
        insert into drm_perf_plan (
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updatePerfPlan" parameterType="PerfPlan">
        update drm_perf_plan
        <set>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where plan_id = #{planId}
    </update>

    <delete id="deletePerfPlanById" parameterType="Long">
        delete from drm_perf_plan where plan_id = #{planId}
    </delete>

    <delete id="deletePerfPlanByIds" parameterType="Long">
        delete from drm_perf_plan where plan_id in
        <foreach item="planId" collection="array" open="(" separator="," close=")">
            #{screenId}
        </foreach>
    </delete>

</mapper>