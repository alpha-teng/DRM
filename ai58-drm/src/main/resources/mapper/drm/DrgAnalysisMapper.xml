<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.DrgAnalysisMapper">

    <resultMap type="DrgAnalysis" id="DrgAnalysisResult">
        <id     property="analysisId"      column="analysis_id"      />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
        <result property="analysisType" column="analysis_type" />
        <result property="deptName" column="dept_name" />
        <result property="drgCode" column="drg_code" />
        <result property="indicatorValue" column="indicator_value" />
        <result property="indicatorName" column="indicator_name" />
    </resultMap>

    <sql id="selectDrgAnalysisVo">
        select analysis_id, analysis_type, dept_name, drg_code, indicator_value, indicator_name, create_by, create_time, update_by, update_time, remark
        from drm_drg_analysis
    </sql>

    <select id="selectDrgAnalysis" parameterType="DrgAnalysis" resultMap="DrgAnalysisResult">
        <include refid="selectDrgAnalysisVo"/>
        <where>
            <if test="analysisId != null">
                and analysis_id = #{screenId}
            </if>
        </where>
    </select>

    <select id="selectDrgAnalysisList" parameterType="DrgAnalysis" resultMap="DrgAnalysisResult">
        <include refid="selectDrgAnalysisVo"/>
        <where>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
    </select>

    <insert id="insertDrgAnalysis" parameterType="DrgAnalysis">
        insert into drm_drg_analysis (
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateDrgAnalysis" parameterType="DrgAnalysis">
        update drm_drg_analysis
        <set>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where analysis_id = #{analysisId}
    </update>

    <delete id="deleteDrgAnalysisById" parameterType="Long">
        delete from drm_drg_analysis where analysis_id = #{analysisId}
    </delete>

    <delete id="deleteDrgAnalysisByIds" parameterType="Long">
        delete from drm_drg_analysis where analysis_id in
        <foreach item="analysisId" collection="array" open="(" separator="," close=")">
            #{screenId}
        </foreach>
    </delete>

</mapper>