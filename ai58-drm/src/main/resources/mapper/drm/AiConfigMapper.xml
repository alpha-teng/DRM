<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.AiConfigMapper">

    <resultMap type="AiConfig" id="AiConfigResult">
        <id     property="configId"      column="config_id"      />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
        <result property="configKey" column="config_key" />
        <result property="configValue" column="config_value" />
    </resultMap>

    <sql id="selectAiConfigVo">
        select config_id, config_key, config_value, create_by, create_time, update_by, update_time, remark
        from drm_ai_config
    </sql>

    <select id="selectAiConfig" parameterType="AiConfig" resultMap="AiConfigResult">
        <include refid="selectAiConfigVo"/>
        <where>
            <if test="configId != null">
                and config_id = #{screenId}
            </if>
        </where>
    </select>

    <select id="selectAiConfigList" parameterType="AiConfig" resultMap="AiConfigResult">
        <include refid="selectAiConfigVo"/>
        <where>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
    </select>

    <insert id="insertAiConfig" parameterType="AiConfig">
        insert into drm_ai_config (
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateAiConfig" parameterType="AiConfig">
        update drm_ai_config
        <set>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where config_id = #{configId}
    </update>

    <delete id="deleteAiConfigById" parameterType="Long">
        delete from drm_ai_config where config_id = #{configId}
    </delete>

    <delete id="deleteAiConfigByIds" parameterType="Long">
        delete from drm_ai_config where config_id in
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{screenId}
        </foreach>
    </delete>

</mapper>