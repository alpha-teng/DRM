<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.AiWarningMapper">

    <resultMap type="DrmAiWarning" id="AiWarningResult">
        <result property="warningId"    column="warning_id"    />
        <result property="warningTitle"    column="warning_title"    />
        <result property="deptName"    column="dept_name"    />
        <result property="warningLevel"    column="warning_level"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectAiWarningVo">
        select warning_id, warning_title, dept_name, warning_level, status, create_by, create_time, update_by, update_time, remark from drm_ai_warning
    </sql>

    <select id="selectAiWarningList" parameterType="DrmAiWarning" resultMap="AiWarningResult">
        <include refid="selectAiWarningVo"/>
        <where>  
            <if test="warningTitle != null and warningTitle != ''"> and warning_title like concat('%', #{warningTitle}, '%')</if>
            <if test="deptName != null and deptName != ''"> and dept_name = #{deptName}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectAiWarningById" parameterType="Long" resultMap="AiWarningResult">
        <include refid="selectAiWarningVo"/>
        where warning_id = #{id}
    </select>
        
    <insert id="insertAiWarning" parameterType="DrmAiWarning" useGeneratedKeys="true" keyProperty="warningId">
        insert into drm_ai_warning
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="warningTitle != null">warning_title,</if>
            <if test="deptName != null">dept_name,</if>
            <if test="warningLevel != null">warning_level,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="warningTitle != null">#{warningTitle},</if>
            <if test="deptName != null">#{deptName},</if>
            <if test="warningLevel != null">#{warningLevel},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiWarning" parameterType="DrmAiWarning">
        update drm_ai_warning
        <trim prefix="SET" suffixOverrides=",">
            <if test="warningTitle != null">warning_title = #{warningTitle},</if>
            <if test="deptName != null">dept_name = #{deptName},</if>
            <if test="warningLevel != null">warning_level = #{warningLevel},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where warning_id = #{warningId}
    </update>

    <delete id="deleteAiWarningById" parameterType="Long">
        delete from drm_ai_warning where warning_id = #{id}
    </delete>

    <delete id="deleteAiWarningByIds" parameterType="String">
        delete from drm_ai_warning where warning_id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
