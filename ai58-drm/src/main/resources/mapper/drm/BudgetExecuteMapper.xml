<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai58.drm.mapper.BudgetExecuteMapper">
    <resultMap type="BudgetExecute" id="BudgetExecuteResult">
        <result property="executeId"       column="execute_id"       />
        <result property="budgetId"        column="budget_id"        />
        <result property="executeYear"     column="execute_year"     />
        <result property="executeMonth"    column="execute_month"    />
        <result property="deptName"        column="dept_name"        />
        <result property="budgetAmount"    column="budget_amount"    />
        <result property="actualAmount"    column="actual_amount"    />
        <result property="executeRate"     column="execute_rate"     />
        <result property="status"          column="status"           />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
    </resultMap>

    <sql id="selectBudgetExecuteVo">
        select execute_id, budget_id, execute_year, execute_month, dept_name, budget_amount,
               actual_amount, execute_rate, status, create_by, create_time, update_by, update_time, remark
        from drm_budget_execute
    </sql>

    <select id="selectBudgetExecuteList" parameterType="BudgetExecute" resultMap="BudgetExecuteResult">
        <include refid="selectBudgetExecuteVo"/>
        <where>
            <if test="budgetId != null"> and budget_id = #{budgetId}</if>
            <if test="executeYear != null and executeYear != ''"> and execute_year = #{executeYear}</if>
            <if test="executeMonth != null and executeMonth != ''"> and execute_month = #{executeMonth}</if>
            <if test="deptName != null and deptName != ''"> and dept_name like concat('%', #{deptName}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectBudgetExecuteById" parameterType="Long" resultMap="BudgetExecuteResult">
        <include refid="selectBudgetExecuteVo"/>
        where execute_id = #{executeId}
    </select>

    <insert id="insertBudgetExecute" parameterType="BudgetExecute" useGeneratedKeys="true" keyProperty="executeId">
        insert into drm_budget_execute
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="budgetId != null">budget_id,</if>
            <if test="executeYear != null and executeYear != ''">execute_year,</if>
            <if test="executeMonth != null and executeMonth != ''">execute_month,</if>
            <if test="deptName != null and deptName != ''">dept_name,</if>
            <if test="budgetAmount != null">budget_amount,</if>
            <if test="actualAmount != null">actual_amount,</if>
            <if test="executeRate != null">execute_rate,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="budgetId != null">#{budgetId},</if>
            <if test="executeYear != null and executeYear != ''">#{executeYear},</if>
            <if test="executeMonth != null and executeMonth != ''">#{executeMonth},</if>
            <if test="deptName != null and deptName != ''">#{deptName},</if>
            <if test="budgetAmount != null">#{budgetAmount},</if>
            <if test="actualAmount != null">#{actualAmount},</if>
            <if test="executeRate != null">#{executeRate},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateBudgetExecute" parameterType="BudgetExecute">
        update drm_budget_execute
        <trim prefix="SET" suffixOverrides=",">
            <if test="budgetId != null">budget_id = #{budgetId},</if>
            <if test="executeYear != null and executeYear != ''">execute_year = #{executeYear},</if>
            <if test="executeMonth != null and executeMonth != ''">execute_month = #{executeMonth},</if>
            <if test="deptName != null and deptName != ''">dept_name = #{deptName},</if>
            <if test="budgetAmount != null">budget_amount = #{budgetAmount},</if>
            <if test="actualAmount != null">actual_amount = #{actualAmount},</if>
            <if test="executeRate != null">execute_rate = #{executeRate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where execute_id = #{executeId}
    </update>

    <delete id="deleteBudgetExecuteById" parameterType="Long">
        delete from drm_budget_execute where execute_id = #{executeId}
    </delete>

    <delete id="deleteBudgetExecuteByIds" parameterType="Long">
        delete from drm_budget_execute where execute_id in
        <foreach item="executeId" collection="array" open="(" separator="," close=")">
            #{executeId}
        </foreach>
    </delete>
</mapper>
